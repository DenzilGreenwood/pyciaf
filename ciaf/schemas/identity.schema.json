{
  "$id": "https://cognitiveinsight.ai/schemas/identity.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CIAF Agentic Identity",
  "description": "Immutable identity for an agent or human principal",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "principal_id",
    "principal_type",
    "display_name"
  ],
  "properties": {
    "principal_id": {
      "type": "string",
      "description": "Unique principal identifier"
    },
    "principal_type": {
      "$ref": "common/enums/principal-type.json",
      "description": "Type of principal"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Assigned roles"
    },
    "attributes": {
      "type": "object",
      "description": "Additional principal attributes"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant/organization identifier"
    },
    "environment": {
      "$ref": "common/enums/environment-type.json",
      "description": "Environment where principal operates"
    },
    "created_at": {
      "$ref": "common/patterns/timestamp.json",
      "description": "ISO 8601 creation timestamp"
    }
  },
  "additionalProperties": false
}
