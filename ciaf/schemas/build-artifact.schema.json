{
  "$id": "https://cognitiveinsight.ai/schemas/build-artifact.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CIAF Build Artifact",
  "description": "Build artifact metadata for deployment",
  "type": "object",
  "required": [
    "artifact_type",
    "artifact_digest",
    "build_timestamp",
    "builder_info"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "wheel",
        "docker",
        "binary",
        "onnx",
        "torchscript",
        "savedmodel",
        "jar",
        "war"
      ],
      "description": "Type of build artifact"
    },
    "artifact_digest": {
      "$ref": "common/identifiers/sha256-hash.json",
      "description": "SHA-256 digest of artifact"
    },
    "build_timestamp": {
      "$ref": "common/patterns/timestamp.json",
      "description": "ISO 8601 timestamp of build"
    },
    "builder_info": {
      "type": "string",
      "description": "Build system or CI/CD information"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Artifact size in bytes"
    }
  },
  "additionalProperties": false
}
