{
  "$id": "https://cognitiveinsight.ai/schemas/deployment-anchor.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CIAF Deployment Anchor",
  "description": "Deployment anchor for LCM with infrastructure tracking",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "deployment_id",
    "predeployment_anchor",
    "deployment_time"
  ],
  "properties": {
    "deployment_id": {
      "type": "string",
      "description": "Unique deployment identifier"
    },
    "predeployment_anchor": {
      "$ref": "predeployment-anchor.schema.json",
      "description": "Associated pre-deployment anchor"
    },
    "deployment_time": {
      "$ref": "common/patterns/timestamp.json",
      "description": "Actual deployment timestamp"
    },
    "deployment_env": {
      "$ref": "common/enums/environment-type.json",
      "description": "Actual deployment environment"
    },
    "location": {
      "type": "string",
      "description": "Actual deployment location/region"
    },
    "infrastructure_hash": {
      "$ref": "common/identifiers/sha256-hash.json",
      "description": "SHA-256 hash of infrastructure specification"
    },
    "config_digest": {
      "$ref": "common/identifiers/sha256-hash.json",
      "description": "SHA-256 digest of runtime configuration"
    },
    "deployment_hash": {
      "$ref": "common/identifiers/sha256-hash.json",
      "description": "SHA-256 hash of deployment data"
    },
    "anchor_id": {
      "type": "string",
      "description": "Anchor identifier (dp_hash prefix)"
    },
    "status": {
      "type": "string",
      "enum": [
        "prepared",
        "deployed",
        "failed",
        "rollback"
      ],
      "description": "Deployment status"
    },
    "signature": {
      "$ref": "common/signature-envelope.json",
      "description": "Cryptographic signature envelope"
    }
  },
  "allOf": [
    {
      "$ref": "lineage-references.schema.json"
    }
  ],
  "additionalProperties": false
}
