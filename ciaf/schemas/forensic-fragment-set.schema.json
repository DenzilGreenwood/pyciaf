{
  "$id": "https://cognitiveinsight.ai/schemas/forensic-fragment-set.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CIAF Forensic Fragment Set",
  "description": "Collection of forensic fragments forming the DNA of an artifact",
  "type": "object",
  "required": ["fragment_count", "sampling_strategy", "total_coverage_percent"],
  "properties": {
    "fragment_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of fragments"
    },
    "sampling_strategy": {
      "type": "string",
      "enum": ["multi_point", "spatial_diversity", "temporal", "entropy_based"],
      "description": "Sampling strategy used"
    },
    "total_coverage_percent": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 100.0,
      "description": "Estimated percentage of content represented"
    },
    "text_fragments": {
      "type": "array",
      "items": { "$ref": "text-forensic-fragment.schema.json" },
      "description": "Text forensic fragments"
    },
    "image_fragments": {
      "type": "array",
      "items": { "$ref": "image-forensic-fragment.schema.json" },
      "description": "Image forensic fragments"
    },
    "video_snippets": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Video forensic snippets"
    },
    "audio_segments": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Audio forensic segments"
    },
    "min_entropy_threshold": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.6,
      "description": "Minimum entropy threshold for inclusion"
    },
    "cumulative_entropy_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Average entropy of selected fragments"
    }
  },
  "additionalProperties": false
}
