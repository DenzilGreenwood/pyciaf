{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cognitiveinsight.ai/schemas/anchor.v1.json",
  "title": "CIAF Anchor Schema",
  "description": "Schema for signed anchor records",
  "type": "object",
  "required": [
    "root",
    "policy_id", 
    "schema_version",
    "timestamp",
    "domain_labels",
    "signature",
    "signing_key_id"
  ],
  "properties": {
    "root": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "Merkle root hash"
    },
    "policy_id": {
      "type": "string",
      "description": "Policy identifier"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semantic versioning)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of anchor creation"
    },
    "domain_labels": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true,
      "description": "Domain labels for this anchor"
    },
    "signature": {
      "type": "string",
      "description": "Digital signature of anchor"
    },
    "signing_key_id": {
      "type": "string", 
      "description": "Identifier of signing key"
    },
    "external_anchor": {
      "type": "string",
      "description": "Optional external timestamp or blockchain anchor"
    }
  }
}